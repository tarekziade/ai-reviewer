# This file is copied to /etc/reviewbot/reviewbot-web.env by deploy.sh.
# If GITHUB_PRIVATE_KEY_PATH points to a local PEM, deploy.sh uploads that file
# to /etc/reviewbot/github-app.pem and rewrites the env file automatically.

# --- GitHub App (used to publish reviews) ---
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=/path/to/pem

# --- LLM ---
LLM_STREAM=1
LLM_API_BASE=https://router.huggingface.co/v1
LLM_BILL_TO=your-org
LLM_MODEL=moonshotai/Kimi-K2.6
LLM_API_KEY=sk-...
# LLM_MAX_TOKENS=4096

# --- Web auth ---
GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxx
GITHUB_OAUTH_CLIENT_SECRET=change-me
GITHUB_OAUTH_CALLBACK_URL=http://your-host:8080/auth/callback
# Generate a strong secret with: openssl rand -hex 32
# Required (no fallback) when DEV_NO_AUTH is off. deploy.sh will mint one
# automatically if you leave this as `replace-me`.
WEB_SESSION_SECRET=replace-me
# DEV_NO_AUTH=1 disables OAuth and access control AND drops the Secure
# flag from the session cookie so plain-HTTP works behind a VPN. Turn it
# off only when the service is reachable over HTTPS — otherwise sessions
# travel in clear text.
DEV_NO_AUTH=1
# If you turn DEV_NO_AUTH off, set one of:
# WEB_ALLOWED_USERS=octocat
# WEB_ALLOWED_ORG=acme

# --- App behavior ---
MENTION_TRIGGER=@serge
REVIEW_EVENT=COMMENT
MAX_DIFF_CHARS=200000
REVIEW_RULES_PATH=.ai/review-rules.md
DEFAULT_REVIEW_RULES=Apply general Python correctness and security standards.
LOG_LEVEL=INFO

# Optional:
# ALLOW_APPROVE controls whether the publish endpoint will accept an
# APPROVE event. The LLM's choice of event is influenced by attacker-
# controlled PR content, so leave this off unless you trust the reviewer
# operators to verify every APPROVE before clicking publish.
# ALLOW_APPROVE=false
# PERSONA_HEADER=**Serge** says:
# CONTEXT_SCRIPT_PATH=.ai/context-script
# CONTEXT_SCRIPT_TIMEOUT=30
# REPO_CHECKOUT_PATH=
# TOOL_MAX_ITERATIONS=15
# WEB_JOB_TTL_SECONDS=3600
