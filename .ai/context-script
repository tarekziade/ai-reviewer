#!/usr/bin/env python3
"""Dogfood context-script for ai-reviewer itself.

ai-reviewer invokes this with a JSON document on stdin describing the
PR (title, body, modified-files list); whatever we print to stdout gets
stitched into the reviewer's user prompt as repo-supplied context.

The hints below highlight files that have outsized blast radius in this
repo so the reviewer pays them extra attention. Keep this list short
and high-signal — every line burns LLM tokens on every review.
"""

import json
import sys


def main() -> int:
    try:
        payload = json.load(sys.stdin)
    except json.JSONDecodeError as exc:
        print(f"context-script: bad JSON on stdin: {exc}", file=sys.stderr)
        return 1

    files = payload.get("files") or []
    paths = {f["path"] for f in files if isinstance(f, dict) and f.get("path")}
    if not paths:
        return 0

    notes: list[str] = []

    if "prompts.py" in paths:
        notes.append(
            "- `prompts.py` was modified. Prompt templates govern reviewer "
            "behavior and contain the IMMUTABLE CONSTRAINTS / anti-injection "
            "language. Watch for: weakened security wording, removed JSON "
            "schema constraints, or template variable mismatches that would "
            "raise KeyError at format time."
        )

    if "triggers.py" in paths:
        notes.append(
            "- `triggers.py` was modified. This is the trust boundary that "
            "decides who can invoke the reviewer. Verify author_association "
            "checks (MEMBER/OWNER/COLLABORATOR), PR-state checks, and "
            "trigger-phrase matching are unchanged or intentionally tightened "
            "— never loosened."
        )

    if "patch.py" in paths:
        notes.append(
            "- `patch.py` was modified. Diff parsing feeds inline-comment "
            "line anchoring; off-by-one bugs cause comments to attach to the "
            "wrong line or be silently dropped by `_validate_comments`."
        )

    if "github_client.py" in paths:
        notes.append(
            "- `github_client.py` was modified. Verify endpoints, HTTP verbs, "
            "pagination, and that error handling does not silently swallow "
            "auth, 404, or rate-limit failures."
        )

    if "context_script.py" in paths or ".ai/context-script" in paths:
        notes.append(
            "- The context-script feature itself was touched. This script "
            "runs untrusted-ish code from the repo and pipes its output into "
            "the LLM prompt; check timeouts, output size caps, executable-bit "
            "handling, and that failures degrade gracefully (None, never raise)."
        )

    if "requirements.txt" in paths:
        notes.append(
            "- `requirements.txt` changed. Check for unpinned versions, "
            "unnecessary additions, and whether each new dep is genuinely "
            "needed at runtime (vs dev/test only)."
        )

    if "action.yml" in paths:
        notes.append(
            "- `action.yml` was modified. The Action's public interface "
            "changed — verify `README.md` documents any new/removed inputs "
            "and that env-var forwarding in the `run:` block matches the "
            "new inputs."
        )

    if ".ai/review-rules.md" in paths:
        notes.append(
            "- `.ai/review-rules.md` changed. These rules govern the "
            "reviewer's own behavior on this repo; sanity-check that they "
            "still produce focused, scoped feedback and don't conflict with "
            "the IMMUTABLE CONSTRAINTS in `prompts.py`."
        )

    core = {"reviewer.py", "patch.py", "triggers.py", "context_script.py"}
    touched_core = sorted(core & paths)
    test_changes = any(p.startswith("tests/") for p in paths)
    if touched_core and not test_changes:
        notes.append(
            f"- Core file(s) {touched_core} changed without any `tests/` "
            "updates. Consider whether existing tests cover the new behavior "
            "or if a regression test is warranted."
        )

    entrypoints = {"app.py", "action_runner.py"}
    touched_entry = entrypoints & paths
    if touched_entry and not (entrypoints <= paths):
        only = next(iter(touched_entry))
        other = next(iter(entrypoints - touched_entry))
        notes.append(
            f"- `{only}` changed but `{other}` did not. ai-reviewer ships in "
            "two modes (Flask webhook / GitHub Action). A change that fixes "
            "one entry point can silently break the other — verify the "
            "behavior is consistent across both."
        )

    if not notes:
        return 0

    print("Reviewer hints generated by `.ai/context-script` from the changed-file list:")
    print()
    for note in notes:
        print(note)
    return 0


if __name__ == "__main__":
    sys.exit(main())
